# Local development environment variables for SkillSelect backend
# Copy this file to .env and fill in real secrets locally (do NOT commit .env).

MONGODB_URI=mongodb://localhost:27017/skillselect
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10

# Frontend base URL used in reset links
FRONTEND_URL=http://localhost:3000

# Password reset token expiry
PASSWORD_RESET_EXP_MINUTES=15

# SMTP email configuration (required for forgot-password emails)
# Example for Gmail SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=SkillSelectAI <your_email@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
